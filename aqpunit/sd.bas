700 IF SC=40 THEN SC=80:GOTO _main
704 GOTO _finish

710 _init_screen:
712 SET COLOR OFF:
714 IF SC=40 THEN SCREEN 1:CLS:SCREEN 3:RETURN
716 STASH SCREEN:SCREEN 3:CLS:SWAP SCREEN:RETURN

720 _work_screen
724 IF SC=40 THEN SCREEN 1:RETURN
726 SWAP SCREEN:RETURN

730 _main_screen:
732 IF SC=40 THEN SCREEN 3:RETURN
734 SWAP SCREEN:RETURN
